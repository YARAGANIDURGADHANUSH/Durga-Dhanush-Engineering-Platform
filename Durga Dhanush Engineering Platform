<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Durga Dhanush Yaragani — AI Engineer, Backend Developer, Cloud & DevOps. Building LLM applications, REST APIs, RAG systems, and cloud-native pipelines.">
<title>Durga Dhanush Yaragani — Engineering Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#ffffff;--bg-2:#f8f8f7;--bg-3:#f1f0ed;
  --border:#e4e3de;--border-strong:#c9c8c3;
  --text:#0d0d0c;--text-2:#4a4945;--text-3:#9e9d96;
  --accent:#1a56db;--accent-bg:#eff4ff;--accent-border:#bfcffd;
  --teal:#0d7a5f;--teal-bg:#dcf5ed;
  --amber:#92400e;--amber-bg:#fef3c7;
  --font:'Inter',-apple-system,sans-serif;
  --mono:'JetBrains Mono','Fira Code',monospace;
  --r:6px;--rl:10px;
  --shadow:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --shadow-lg:0 8px 24px rgba(0,0,0,.08),0 2px 8px rgba(0,0,0,.04);
  --sw:240px;--tx:.15s ease;
}
[data-theme="dark"]{
  --bg:#0d0d0c;--bg-2:#161614;--bg-3:#1e1e1c;
  --border:#2a2a28;--border-strong:#3d3d3a;
  --text:#f0efe8;--text-2:#b4b2a9;--text-3:#6e6d66;
  --accent:#4e82ee;--accent-bg:#0f1f40;--accent-border:#1e3a70;
  --teal:#34d399;--teal-bg:#052e1e;
  --amber:#fbbf24;--amber-bg:#1c1207;
  --shadow:0 1px 3px rgba(0,0,0,.3);
  --shadow-lg:0 8px 24px rgba(0,0,0,.4);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--text);font-size:15px;line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{color:inherit;text-decoration:none}
button{font-family:var(--font);cursor:pointer;background:none;border:none}
ul,ol{list-style:none}
p{margin-bottom:14px;color:var(--text-2)}
p:last-child{margin-bottom:0}
h1,h2,h3,h4{color:var(--text);font-weight:600;letter-spacing:-.02em;line-height:1.25}
h1{font-size:28px}h2{font-size:22px;margin-bottom:8px}h3{font-size:17px;margin-bottom:6px}
h4{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--text-3);font-family:var(--mono);margin-bottom:10px}
code{font-family:var(--mono);font-size:12px;background:var(--bg-3);padding:2px 6px;border-radius:4px;color:var(--accent)}
hr{border:none;border-top:1px solid var(--border);margin:28px 0}
/* LAYOUT */
.layout{display:flex;min-height:100vh}
.sidebar{width:var(--sw);flex-shrink:0;position:fixed;top:0;left:0;bottom:0;background:var(--bg-2);border-right:1px solid var(--border);overflow-y:auto;z-index:50;display:flex;flex-direction:column;transition:transform var(--tx)}
.main{margin-left:var(--sw);flex:1;min-width:0}
.topbar{position:sticky;top:0;z-index:40;background:var(--bg);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 32px;height:52px;gap:12px}
.content-area{max-width:844px;margin:0 auto;padding:48px 32px}
/* SIDEBAR */
.sidebar-header{padding:16px 16px 10px;border-bottom:1px solid var(--border)}
.sidebar-avatar{width:36px;height:36px;border-radius:8px;background:var(--accent-bg);border:1px solid var(--accent-border);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;color:var(--accent);font-family:var(--mono);margin-bottom:10px}
.sidebar-name{font-size:13px;font-weight:600;color:var(--text);line-height:1.3}
.sidebar-role{font-size:11px;color:var(--text-3);margin-top:2px}
.sidebar-search{margin:10px 12px 4px;background:var(--bg-3);border:1px solid var(--border);border-radius:var(--r);display:flex;align-items:center;gap:6px;padding:6px 10px;cursor:pointer;width:calc(100% - 24px)}
.sidebar-search span{font-size:12px;color:var(--text-3)}
.sidebar-search kbd{margin-left:auto;font-size:10px;color:var(--text-3);background:var(--bg-2);border:1px solid var(--border);border-radius:3px;padding:1px 4px;font-family:var(--mono)}
.nav-section{padding:10px 12px 2px}
.nav-section-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--text-3);padding:0 6px;margin-bottom:4px}
.nav-item{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:var(--r);font-size:13px;color:var(--text-2);cursor:pointer;transition:background var(--tx),color var(--tx);width:100%}
.nav-item:hover{background:var(--bg-3);color:var(--text)}
.nav-item.active{background:var(--accent-bg);color:var(--accent)}
.nav-icon{width:15px;flex-shrink:0;opacity:.55}
.nav-item.active .nav-icon{opacity:1}
.nav-badge{margin-left:auto;font-size:10px;font-weight:600;background:var(--bg-3);color:var(--text-3);border-radius:100px;padding:1px 6px;font-family:var(--mono)}
.sidebar-footer{margin-top:auto;padding:12px;border-top:1px solid var(--border);display:flex;align-items:center;gap:6px}
.theme-toggle{flex:1;display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-3);padding:6px 8px;border-radius:var(--r);transition:background var(--tx)}
.theme-toggle:hover{background:var(--bg-3);color:var(--text)}
.sb-link{width:30px;height:30px;border-radius:var(--r);display:flex;align-items:center;justify-content:center;color:var(--text-3);transition:background var(--tx),color var(--tx)}
.sb-link:hover{background:var(--bg-3);color:var(--text)}
/* TOPBAR */
.topbar-bc{font-size:13px;color:var(--text-3);display:flex;align-items:center;gap:6px}
.topbar-bc .sep{color:var(--border-strong)}
.topbar-bc .cur{color:var(--text);font-weight:500}
.topbar-actions{margin-left:auto;display:flex;align-items:center;gap:8px}
.tbtn{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:500;padding:5px 12px;border-radius:var(--r);border:1px solid var(--border);color:var(--text-2);transition:all var(--tx)}
.tbtn:hover{border-color:var(--border-strong);color:var(--text);background:var(--bg-2)}
.tbtn.accent{background:var(--accent);color:#fff;border-color:var(--accent)}
.tbtn.accent:hover{opacity:.9}
.hamburger{display:none;align-items:center;justify-content:center;width:32px;height:32px;border-radius:var(--r);color:var(--text-2);margin-right:8px}
.hamburger:hover{background:var(--bg-2)}
/* PAGES */
.page{display:none}
.page.active{display:block}
/* HERO */
.hero-status{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:600;font-family:var(--mono);padding:4px 10px;border-radius:100px;background:var(--teal-bg);color:var(--teal);border:1px solid rgba(13,122,95,.2);margin-bottom:20px}
[data-theme="dark"] .hero-status{border-color:rgba(52,211,153,.2)}
.hero-dot{width:6px;height:6px;border-radius:50%;background:var(--teal);animation:sPulse 2s ease-in-out infinite}
@keyframes sPulse{0%,100%{opacity:1}50%{opacity:.4}}
.hero-name{font-size:clamp(30px,4.5vw,48px);font-weight:600;letter-spacing:-.03em;line-height:1.08;color:var(--text);margin-bottom:6px}
.hero-title{font-size:18px;color:var(--text-3);font-weight:400;margin-bottom:20px;letter-spacing:-.01em}
.hero-lead{font-size:15px;max-width:600px;line-height:1.75;color:var(--text-2);margin-bottom:28px}
.hero-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;margin-bottom:28px}
.metric-cell{background:var(--bg);padding:16px 20px}
.metric-n{font-size:22px;font-weight:600;letter-spacing:-.02em;color:var(--text);font-family:var(--mono);margin-bottom:2px}
.metric-label{font-size:11px;color:var(--text-3);line-height:1.4}
.hero-tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:24px}
.tag{font-size:11px;font-family:var(--mono);padding:3px 8px;border-radius:var(--r);background:var(--bg-3);color:var(--text-2);border:1px solid var(--border)}
.tag.hl{background:var(--accent-bg);color:var(--accent);border-color:var(--accent-border)}
.hero-ctas{display:flex;flex-wrap:wrap;gap:10px}
.cta{display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:500;padding:8px 16px;border-radius:var(--r);border:1px solid var(--border);color:var(--text-2);transition:all var(--tx)}
.cta:hover{border-color:var(--border-strong);color:var(--text);background:var(--bg-2)}
.cta.primary{background:var(--text);color:var(--bg);border-color:var(--text)}
.cta.primary:hover{opacity:.85}
/* TIMELINE */
.timeline{position:relative;padding-left:28px}
.timeline::before{content:'';position:absolute;left:7px;top:8px;bottom:8px;width:1px;background:var(--border)}
.tl-entry{position:relative;margin-bottom:32px}
.tl-entry:last-child{margin-bottom:0}
.tl-dot{position:absolute;left:-24px;top:6px;width:14px;height:14px;border-radius:50%;background:var(--bg);border:2px solid var(--border);transition:border-color var(--tx)}
.tl-entry:hover .tl-dot{border-color:var(--accent)}
.tl-dot.done{background:var(--accent);border-color:var(--accent)}
.tl-dot.current{background:var(--teal);border-color:var(--teal);box-shadow:0 0 0 3px var(--teal-bg)}
.tl-dot.next{border-style:dashed}
.tl-meta{display:flex;align-items:baseline;gap:10px;margin-bottom:4px;flex-wrap:wrap}
.tl-period{font-size:11px;font-family:var(--mono);color:var(--text-3)}
.tl-title{font-size:15px;font-weight:600;color:var(--text)}
.tl-body{font-size:13px;color:var(--text-2);line-height:1.6}
.chips{display:flex;flex-wrap:wrap;gap:4px;margin-top:8px}
.chip{font-size:10px;font-family:var(--mono);padding:2px 7px;border-radius:var(--r);background:var(--bg-3);color:var(--text-3);border:1px solid var(--border)}
/* PROJECT CARDS */
.pfilters{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:20px}
.fbtn{font-size:11px;font-weight:500;padding:4px 12px;border-radius:100px;border:1px solid var(--border);color:var(--text-3);transition:all var(--tx)}
.fbtn:hover{border-color:var(--border-strong);color:var(--text)}
.fbtn.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.pgrid{display:flex;flex-direction:column;gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden}
.prow{background:var(--bg);padding:20px 24px;display:grid;grid-template-columns:1fr auto;gap:16px;align-items:start;cursor:pointer;transition:background var(--tx)}
.prow:hover{background:var(--bg-2)}
.prow-name{font-size:15px;font-weight:600;color:var(--text);margin-bottom:4px}
.prow-desc{font-size:13px;color:var(--text-2);line-height:1.5;margin-bottom:10px}
.prow-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.pfocus{font-size:10px;font-weight:600;font-family:var(--mono);padding:2px 8px;border-radius:var(--r);white-space:nowrap}
.f-ai{background:#f0fdf4;color:#166534}
.f-backend{background:#fdf4ff;color:#7e22ce}
.f-cloud{background:var(--amber-bg);color:var(--amber)}
.f-devops{background:#fff7ed;color:#c2410c}
.f-arch{background:var(--accent-bg);color:var(--accent)}
[data-theme="dark"] .f-ai{background:#052e16;color:#34d399}
[data-theme="dark"] .f-backend{background:#1e0b2e;color:#c084fc}
[data-theme="dark"] .f-cloud{background:#1c1207;color:var(--amber)}
[data-theme="dark"] .f-devops{background:#1c0a00;color:#fb923c}
.parrow{color:var(--text-3);font-size:18px;margin-top:2px;transition:transform var(--tx),color var(--tx)}
.prow:hover .parrow{transform:translateX(3px);color:var(--text)}
/* PROJECT DETAIL */
.pdetail{display:none}
.pdetail.open{display:block}
.back-btn{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--text-3);margin-bottom:28px;padding:6px 10px;border-radius:var(--r);transition:all var(--tx)}
.back-btn:hover{background:var(--bg-2);color:var(--text)}
/* CALLOUTS */
.callout{padding:14px 18px;border-radius:var(--rl);margin:18px 0;border-left:3px solid}
.callout.info{background:var(--accent-bg);border-color:var(--accent)}
.callout.success{background:var(--teal-bg);border-color:var(--teal)}
.callout.warning{background:var(--amber-bg);border-color:var(--amber)}
.callout.note{background:var(--bg-3);border-color:var(--border-strong)}
.callout-title{font-size:10px;font-weight:600;font-family:var(--mono);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.callout.info .callout-title{color:var(--accent)}
.callout.success .callout-title{color:var(--teal)}
.callout.warning .callout-title{color:var(--amber)}
.callout.note .callout-title{color:var(--text-3)}
.callout p{font-size:13px;margin:0;line-height:1.65;color:inherit}
.callout.info p,.callout.info .callout-title~p{color:var(--accent)}
.callout.success p{color:var(--teal)}
.callout.warning p{color:var(--amber)}
.callout.note p{color:var(--text-2)}
/* CODE BLOCKS */
.cblock{background:var(--bg-3);border:1px solid var(--border);border-radius:var(--rl);overflow-x:auto;margin:16px 0}
.cblock-hdr{display:flex;align-items:center;gap:8px;padding:10px 16px;border-bottom:1px solid var(--border)}
.cblock-lbl{font-size:11px;font-family:var(--mono);color:var(--text-3)}
.cblock-lang{margin-left:auto;font-size:10px;font-family:var(--mono);color:var(--text-3);background:var(--bg-2);border:1px solid var(--border);padding:1px 6px;border-radius:3px}
.cblock pre{padding:16px;font-family:var(--mono);font-size:12px;color:var(--text-2);line-height:1.8;white-space:pre}
.ac1{color:var(--text);font-weight:500}
.ac2{color:var(--accent)}
.ac3{color:var(--teal)}
.ac4{color:var(--text-3);font-style:italic}
/* GRID */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:16px 0}
.icard{background:var(--bg-2);border:1px solid var(--border);border-radius:var(--rl);padding:18px}
.icard h4{margin-bottom:10px}
.ilist{display:flex;flex-direction:column;gap:7px}
.ilist li{font-size:13px;color:var(--text-2);display:flex;gap:10px;align-items:flex-start;line-height:1.5}
.ilist li::before{content:'→';color:var(--text-3);flex-shrink:0;margin-top:1px;font-size:12px}
.tpills{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px}
.tpill{font-size:11px;font-family:var(--mono);padding:3px 9px;border:1px solid var(--border);border-radius:var(--r);color:var(--text-2);background:var(--bg)}
.tpill.hl{background:var(--accent-bg);color:var(--accent);border-color:var(--accent-border)}
/* SKILLS */
.sg-block{border-top:2px solid var(--text);padding-top:12px;margin-bottom:28px}
.sg-title{font-size:11px;font-weight:600;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--text);margin-bottom:12px}
.skill-row{display:flex;align-items:center;gap:12px;margin-bottom:8px}
.skill-name{font-size:13px;color:var(--text-2);min-width:180px}
.skill-track{flex:1;height:4px;background:var(--bg-3);border-radius:100px;overflow:hidden}
.skill-fill{height:100%;border-radius:100px}
.b-confident{background:var(--teal)}
.b-working{background:var(--accent)}
.b-learning{background:var(--amber)}
.skill-lbl{font-size:10px;font-family:var(--mono);color:var(--text-3);min-width:72px;text-align:right}
/* CERTS */
.cert-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px}
.cert-card{background:var(--bg-2);border:1px solid var(--border);border-radius:var(--rl);padding:16px 18px;transition:border-color var(--tx)}
.cert-card:hover{border-color:var(--border-strong)}
.cert-issuer{font-size:10px;font-family:var(--mono);text-transform:uppercase;letter-spacing:.08em;color:var(--text-3);margin-bottom:6px}
.cert-name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:6px;line-height:1.35}
.cert-desc{font-size:12px;color:var(--text-3);line-height:1.55}
/* JOURNEY */
.jgrid{display:grid;grid-template-columns:1fr 1fr 1fr;border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;gap:1px;background:var(--border)}
.jcol{background:var(--bg);padding:20px}
.jcol-title{font-size:10px;font-weight:600;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;padding-bottom:10px;margin-bottom:14px;border-bottom:2px solid}
.j-confident .jcol-title{color:var(--teal);border-color:var(--teal)}
.j-active .jcol-title{color:var(--accent);border-color:var(--accent)}
.j-next .jcol-title{color:var(--text-3);border-color:var(--border-strong)}
.jitems{display:flex;flex-direction:column;gap:7px}
.jitems li{font-size:13px;color:var(--text-2);line-height:1.5}
/* GUIDE */
.guide-wrap{border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;display:flex;flex-direction:column;height:520px;background:var(--bg)}
.guide-hdr{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;background:var(--bg-2)}
.guide-av{width:28px;height:28px;border-radius:6px;background:var(--accent-bg);border:1px solid var(--accent-border);display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--accent);font-family:var(--mono);font-weight:600}
.guide-ttl{font-size:13px;font-weight:600;color:var(--text)}
.guide-sub{font-size:11px;color:var(--text-3)}
.mode-pills{margin-left:auto;display:flex;gap:4px}
.mpill{font-size:10px;font-family:var(--mono);padding:3px 8px;border-radius:100px;border:1px solid var(--border);color:var(--text-3);transition:all var(--tx)}
.mpill.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.guide-msgs{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px}
.gmsg{display:flex;gap:10px;max-width:90%}
.gmsg.user{margin-left:auto;flex-direction:row-reverse}
.mav{width:24px;height:24px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;font-family:var(--mono)}
.gmsg.assistant .mav{background:var(--accent-bg);color:var(--accent);border:1px solid var(--accent-border)}
.gmsg.user .mav{background:var(--bg-3);color:var(--text-3);border:1px solid var(--border)}
.mbubble{padding:10px 14px;border-radius:10px;font-size:13px;line-height:1.65}
.gmsg.assistant .mbubble{background:var(--bg-2);color:var(--text-2);border:1px solid var(--border);border-top-left-radius:2px}
.gmsg.user .mbubble{background:var(--accent);color:#fff;border-top-right-radius:2px}
.gmsg.assistant .mbubble p{color:var(--text-2);font-size:13px}
.typing-dots{display:flex;gap:4px;align-items:center;padding:4px 0}
.typing-dots span{width:5px;height:5px;border-radius:50%;background:var(--text-3);animation:tdot 1.2s ease-in-out infinite}
.typing-dots span:nth-child(2){animation-delay:.2s}
.typing-dots span:nth-child(3){animation-delay:.4s}
@keyframes tdot{0%,80%,100%{transform:scale(.6);opacity:.4}40%{transform:scale(1);opacity:1}}
.guide-sugg{padding:10px 16px;border-top:1px solid var(--border);display:flex;gap:6px;flex-wrap:wrap;background:var(--bg-2)}
.sug-chip{font-size:11px;padding:4px 10px;border-radius:100px;border:1px solid var(--border);color:var(--text-2);background:var(--bg);transition:all var(--tx)}
.sug-chip:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-bg)}
.guide-input-row{display:flex;gap:8px;padding:12px 16px;border-top:1px solid var(--border);background:var(--bg)}
.ginput{flex:1;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--r);padding:8px 12px;font-size:13px;color:var(--text);font-family:var(--font);outline:none;transition:border-color var(--tx)}
.ginput:focus{border-color:var(--accent)}
.ginput::placeholder{color:var(--text-3)}
.gsend{padding:8px 14px;background:var(--accent);color:#fff;border-radius:var(--r);font-size:12px;font-weight:600;transition:opacity var(--tx)}
.gsend:hover{opacity:.88}
/* COMMAND PALETTE */
.pal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;display:none;align-items:flex-start;justify-content:center;padding-top:15vh;backdrop-filter:blur(2px)}
.pal-overlay.open{display:flex}
.pal-box{width:100%;max-width:560px;background:var(--bg);border:1px solid var(--border-strong);border-radius:12px;box-shadow:var(--shadow-lg);overflow:hidden}
.pal-input-row{display:flex;align-items:center;gap:10px;padding:14px 16px;border-bottom:1px solid var(--border)}
.pal-input{flex:1;background:none;border:none;outline:none;font-size:15px;color:var(--text);font-family:var(--font)}
.pal-input::placeholder{color:var(--text-3)}
.pal-results{max-height:380px;overflow-y:auto;padding:6px}
.pal-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:var(--r);font-size:13px;color:var(--text-2);cursor:pointer;transition:background var(--tx),color var(--tx)}
.pal-item:hover,.pal-item.sel{background:var(--accent-bg);color:var(--accent)}
.pal-type{font-size:10px;font-family:var(--mono);color:var(--text-3);background:var(--bg-3);padding:2px 6px;border-radius:3px;margin-left:auto;white-space:nowrap}
.pal-footer{padding:8px 14px;border-top:1px solid var(--border);display:flex;gap:16px;background:var(--bg-2)}
.pal-hint{font-size:11px;color:var(--text-3);display:flex;align-items:center;gap:4px}
.pal-hint kbd{font-size:10px;background:var(--bg);border:1px solid var(--border);border-radius:3px;padding:1px 4px;font-family:var(--mono);color:var(--text-3)}
/* GITHUB */
.repo-list{display:flex;flex-direction:column;gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden}
.repo-row{background:var(--bg);padding:18px 22px;display:grid;grid-template-columns:1fr 180px 140px;gap:16px;align-items:start;transition:background var(--tx)}
.repo-row:hover{background:var(--bg-2)}
.repo-name{font-size:13px;font-weight:600;font-family:var(--mono);color:var(--accent);margin-bottom:3px}
.repo-desc{font-size:12px;color:var(--text-3);line-height:1.5;margin-bottom:8px}
.repo-concepts{font-size:11px;color:var(--text-2);line-height:1.6}
.repo-stack{font-size:11px;font-family:var(--mono);color:var(--text-3);line-height:1.7}
.repo-stat{text-align:right}
.sbadge{font-size:10px;font-family:var(--mono);padding:2px 8px;border-radius:100px;display:inline-flex;align-items:center;gap:4px}
.sbadge.active{background:var(--teal-bg);color:var(--teal)}
.sbadge.building{background:var(--amber-bg);color:var(--amber)}
.sbadge-dot{width:5px;height:5px;border-radius:50%;background:currentColor}
/* PHILOSOPHY */
.phil-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden}
.pcell{background:var(--bg);padding:20px 22px;border-top:3px solid transparent;transition:border-color var(--tx)}
.pcell:hover{border-top-color:var(--accent)}
.pcell-title{font-size:14px;font-weight:600;color:var(--text);margin-bottom:6px}
.pcell-text{font-size:13px;color:var(--text-2);line-height:1.65}
/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.citem{display:flex;align-items:center;gap:12px;padding:14px 16px;border:1px solid var(--border);border-radius:var(--rl);background:var(--bg-2);transition:border-color var(--tx)}
.citem:hover{border-color:var(--border-strong)}
.citem-lbl{font-size:10px;font-family:var(--mono);color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px}
.citem-val{font-size:13px;font-weight:500;color:var(--text)}
/* READING BAR */
.rbar{position:fixed;top:0;left:0;height:2px;background:var(--accent);z-index:999;transition:width .1s linear}
/* PRINT */
@media print{.sidebar,.topbar,.pal-overlay,.guide-wrap{display:none!important}.main{margin-left:0!important}.content-area{padding:20px!important}.page{display:block!important}}
/* RESPONSIVE */
@media(max-width:768px){.sidebar{transform:translateX(-100%)}.sidebar.open{transform:translateX(0)}.main{margin-left:0}.hamburger{display:flex}.two-col,.jgrid,.phil-grid,.contact-grid{grid-template-columns:1fr}.hero-metrics{grid-template-columns:1fr 1fr}.repo-row{grid-template-columns:1fr}.repo-stack,.repo-stat{display:none}.mode-pills{display:none}}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
</style>
</head>
