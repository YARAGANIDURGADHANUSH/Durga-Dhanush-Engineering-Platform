// ── PALETTE ───────────────────────────────────────────────────
function openPal(){
  document.getElementById('cmdPal').classList.add('open');
  document.getElementById('palInput').value='';
  renderPal('');
  setTimeout(()=>document.getElementById('palInput').focus(),50);
  palSel=-1;
}
function closePal(){document.getElementById('cmdPal').classList.remove('open');}
document.getElementById('palInput').addEventListener('input',e=>{renderPal(e.target.value);palSel=-1;});
function renderPal(q){
  const lo=q.toLowerCase();
  palFiltered=PAL_ITEMS.filter(i=>!q||i.l.toLowerCase().includes(lo)||i.t.includes(lo));
  document.getElementById('palResults').innerHTML=palFiltered.slice(0,8).map((item,i)=>
    `<div class="pal-item" onclick="palGo(${i})"><span>${item.l}</span><span class="pal-type">${item.t}</span></div>`
  ).join('');
}
function palGo(idx){
  const item=palFiltered[idx];if(!item)return;
  closePal();nav(item.p);
  if(item.t==='project'){
    const words=item.l.toLowerCase().split(' ');
    const proj=PROJECTS.find(p=>words.some(w=>p.name.toLowerCase().includes(w)&&w.length>3));
    if(proj)setTimeout(()=>openDetail(proj.id),150);
  }
}
document.getElementById('palInput').addEventListener('keydown',e=>{
  const items=document.querySelectorAll('.pal-item');
  if(e.key==='ArrowDown'){e.preventDefault();palSel=Math.min(palSel+1,items.length-1);hlPal(items);}
  else if(e.key==='ArrowUp'){e.preventDefault();palSel=Math.max(palSel-1,0);hlPal(items);}
  else if(e.key==='Enter'){e.preventDefault();palGo(palSel>=0?palSel:0);}
  else if(e.key==='Escape')closePal();
});
function hlPal(items){items.forEach((el,i)=>el.classList.toggle('sel',i===palSel));if(items[palSel])items[palSel].scrollIntoView({block:'nearest'});}
document.getElementById('cmdPal').addEventListener('click',e=>{if(e.target===document.getElementById('cmdPal'))closePal();});

