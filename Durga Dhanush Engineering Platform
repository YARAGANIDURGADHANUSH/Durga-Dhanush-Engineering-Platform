// ── GUIDE ─────────────────────────────────────────────────────
function setMode(m,btn){
  gMode=m;
  document.querySelectorAll('.mpill').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('gsugg').innerHTML=(MODE_HINTS[m]||MODE_HINTS.general).map(s=>
    `<button class="sug-chip" onclick="useSug(this)">${s}</button>`).join('');
}
function useSug(btn){document.getElementById('ginput').value=btn.textContent;sendMsg();}
async function sendMsg(){
  const inp=document.getElementById('ginput');
  const txt=inp.value.trim();if(!txt)return;
  inp.value='';
  addMsg('user',txt);
  gHistory.push({role:'user',content:txt});
  const tid='t'+Date.now();
  const msgs=document.getElementById('gmsgs');
  msgs.innerHTML+=`<div class="gmsg assistant" id="${tid}"><div class="mav">G</div><div class="mbubble"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>`;
  msgs.scrollTop=msgs.scrollHeight;
  const modeNote={recruiter:'\n\nRespond for a recruiter: focus on role fit, achievements, availability. Be concise.',technical:'\n\nRespond for a technical interviewer: go deep on implementation, trade-offs, architecture.',manager:'\n\nRespond for an engineering manager: emphasise delivery, leadership, team impact.',general:''};
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:1000,system:SYS+(modeNote[gMode]||''),messages:gHistory})
    });
    const data=await res.json();
    const reply=data.content?.find(b=>b.type==='text')?.text||'Unable to generate a response.';
    gHistory.push({role:'assistant',content:reply});
    document.getElementById(tid)?.remove();
    addMsg('assistant',reply);
  }catch(e){
    document.getElementById(tid)?.remove();
    addMsg('assistant','Unable to connect. Please check your network and try again.');
  }
}
function addMsg(role,text){
  const msgs=document.getElementById('gmsgs');
  const fmt=text.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>');
  msgs.innerHTML+=`<div class="gmsg ${role}"><div class="mav">${role==='assistant'?'G':'U'}</div><div class="mbubble">${fmt}</div></div>`;
  msgs.scrollTop=msgs.scrollHeight;
}
</script>
